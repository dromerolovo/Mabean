<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mabean.ViewModels"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="700"
             x:Class="Mabean.Views.BehaviorChainView"
             x:DataType="vm:BehaviorChainViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="#070C14"/>
            <Setter Property="BorderBrush" Value="#2A2E39"/>
            <Setter Property="Foreground" Value="#D1D4DC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="#070C14"/>
            <Setter Property="BorderBrush" Value="#2A2E39"/>
            <Setter Property="Foreground" Value="#D1D4DC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.runBtn">
            <Setter Property="Background" Value="#C6F36E"/>
            <Setter Property="Foreground" Value="#070C14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.runBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D4F87A"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#070C14" RowDefinitions="*,Auto">

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,20,20,12" Spacing="0" MaxWidth="460" HorizontalAlignment="Left">

                <!-- Phase 1: Privilege Escalation -->
                <Border Background="#0D1117" BorderBrush="#2A2E39" BorderThickness="1">
                    <StackPanel>
                        <Border Background="#090E18" BorderBrush="#2A2E39" BorderThickness="0,0,0,1" Padding="14,9">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="PHASE 01" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <Border Width="1" Height="12" Background="#2A2E39" VerticalAlignment="Center"/>
                                    <TextBlock Text="PRIVILEGE ESCALATION" FontSize="10" FontWeight="SemiBold" Foreground="#9FB0D8" VerticalAlignment="Center"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding PrivEscEnabled}" Content="ENABLE"/>
                            </Grid>
                        </Border>
                        <Border IsVisible="{Binding ShowPrivEscFields}" Padding="14,10,14,12">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="110,*" VerticalAlignment="Center">
                                    <TextBlock Text="BEHAVIOR" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding PrivEscBehaviors}"
                                              SelectedItem="{Binding PrivEscBehavior}"
                                              HorizontalAlignment="Stretch"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*" IsVisible="{Binding ShowPrivEscPidField}">
                                    <TextBlock Text="TARGET PID" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding PrivEscTargetPid}" Watermark="Process ID"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Connector -->
                <Border Height="16" Width="1" Background="#2A2E39" HorizontalAlignment="Left" Margin="14,0,0,0"/>

                <!-- Phase 2: Persistence -->
                <Border Background="#0D1117" BorderBrush="#2A2E39" BorderThickness="1">
                    <StackPanel>
                        <Border Background="#090E18" BorderBrush="#2A2E39" BorderThickness="0,0,0,1" Padding="14,9">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="PHASE 02" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <Border Width="1" Height="12" Background="#2A2E39" VerticalAlignment="Center"/>
                                    <TextBlock Text="PERSISTENCE" FontSize="10" FontWeight="SemiBold" Foreground="#9FB0D8" VerticalAlignment="Center"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding PersistenceEnabled}" Content="ENABLE"/>
                            </Grid>
                        </Border>
                        <Border IsVisible="{Binding ShowPersistenceFields}" Padding="14,10,14,12">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="110,*">
                                    <TextBlock Text="BEHAVIOR" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding PersistenceBehaviors}"
                                              SelectedItem="{Binding PersistenceBehavior}"
                                              HorizontalAlignment="Stretch"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*">
                                    <TextBlock Text="SERVICE NAME" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding PersistenceServiceName}" Watermark="MyService"/>
                                </Grid>
                                <CheckBox IsChecked="{Binding PersistenceUseDefaultPath}" Content="USE DEFAULT PATH"/>
                                <Grid ColumnDefinitions="110,*" IsVisible="{Binding ShowPersistenceBinaryPathField}">
                                    <TextBlock Text="BINARY PATH" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding PersistenceBinaryPath}" Watermark="C:\path\to\service.exe"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Connector -->
                <Border Height="16" Width="1" Background="#2A2E39" HorizontalAlignment="Left" Margin="14,0,0,0"/>

                <!-- Phase 3: Injection -->
                <Border Background="#0D1117" BorderBrush="#2A2E39" BorderThickness="1">
                    <StackPanel>
                        <Border Background="#090E18" BorderBrush="#2A2E39" BorderThickness="0,0,0,1" Padding="14,9">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="PHASE 03" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <Border Width="1" Height="12" Background="#2A2E39" VerticalAlignment="Center"/>
                                    <TextBlock Text="INJECTION" FontSize="10" FontWeight="SemiBold" Foreground="#9FB0D8" VerticalAlignment="Center"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding InjectionEnabled}" Content="ENABLE"/>
                            </Grid>
                        </Border>
                        <Border IsVisible="{Binding ShowInjectionFields}" Padding="14,10,14,12">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="110,*">
                                    <TextBlock Text="BEHAVIOR" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding InjectionBehaviors}"
                                              SelectedItem="{Binding InjectionBehavior}"
                                              HorizontalAlignment="Stretch"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*">
                                    <TextBlock Text="PAYLOAD" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Payloads}"
                                              SelectedItem="{Binding InjectionPayloadName}"
                                              HorizontalAlignment="Stretch"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*" IsVisible="{Binding ShowInjectionPidField}">
                                    <TextBlock Text="TARGET PID" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding InjectionTargetPid}" Watermark="Process ID"/>
                                </Grid>
                                <Grid ColumnDefinitions="110,*" IsVisible="{Binding ShowInjectionProgramField}">
                                    <TextBlock Text="PROGRAM" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding InjectionProgramName}" Watermark="Program name"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom action bar -->
        <Border Grid.Row="1"
                Background="#090E18"
                BorderBrush="#2A2E39"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Button Classes="runBtn"
                    Content="RUN CHAIN"
                    HorizontalAlignment="Right"
                    Command="{Binding RunChainCommand}"/>
        </Border>

    </Grid>

</UserControl>
