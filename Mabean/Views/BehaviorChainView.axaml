<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Mabean.ViewModels"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="700"
             x:Class="Mabean.Views.BehaviorChainView"
             x:DataType="vm:BehaviorChainViewModel">

    <Border Padding="20">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">

            <TextBlock Grid.Row="0" Classes="h4" Text="Behavior Chain" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" MaxWidth="520">

                    <Border Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="12" Padding="16" Width="520">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel>
                                    <TextBlock Text="Phase 1" Foreground="#6B7280" FontSize="11" />
                                    <TextBlock Text="Privilege Escalation" FontWeight="SemiBold" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding PrivEscEnabled}" Content="Enable" />
                            </Grid>

                            <StackPanel IsVisible="{Binding ShowPrivEscFields}" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Behavior" Foreground="#9FB0D8" Width="100" VerticalAlignment="Center" />
                                    <ComboBox Width="280"
                                              ItemsSource="{Binding PrivEscBehaviors}"
                                              SelectedItem="{Binding PrivEscBehavior}" />
                                </StackPanel>
                                <StackPanel IsVisible="{Binding ShowPrivEscPidField}" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Target PID" Foreground="#9FB0D8" Width="100" VerticalAlignment="Center" />
                                    <TextBox Width="280" Text="{Binding PrivEscTargetPid}" Watermark="Process ID" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Height="24" Width="2" Background="#2A2A2A" HorizontalAlignment="Center" />

                    <Border Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="12" Padding="16" Width="520">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel>
                                    <TextBlock Text="Phase 2" Foreground="#6B7280" FontSize="11" />
                                    <TextBlock Text="Persistence" FontWeight="SemiBold" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding PersistenceEnabled}" Content="Enable" />
                            </Grid>

                            <StackPanel IsVisible="{Binding ShowPersistenceFields}" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Behavior" Foreground="#9FB0D8" Width="100" VerticalAlignment="Center" />
                                    <ComboBox Width="280"
                                              ItemsSource="{Binding PersistenceBehaviors}"
                                              SelectedItem="{Binding PersistenceBehavior}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Service Name" Foreground="#9FB0D8" Width="100" VerticalAlignment="Center" />
                                    <TextBox Width="280" Text="{Binding PersistenceServiceName}" Watermark="MyService" />
                                </StackPanel>
                                <CheckBox IsChecked="{Binding PersistenceUseDefaultPath}" Content="Use default path" />
                                <StackPanel IsVisible="{Binding ShowPersistenceBinaryPathField}" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Binary Path" Foreground="#9FB0D8" Width="100" VerticalAlignment="Center" />
                                    <TextBox Width="280" Text="{Binding PersistenceBinaryPath}" Watermark="C:\path\to\service.exe" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Height="24" Width="2" Background="#2A2A2A" HorizontalAlignment="Center" />

                    <Border Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="12" Padding="16" Width="520">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel>
                                    <TextBlock Text="Phase 3" Foreground="#6B7280" FontSize="11" />
                                    <TextBlock Text="Injection" FontWeight="SemiBold" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding InjectionEnabled}" Content="Enable" />
                            </Grid>

                            <StackPanel IsVisible="{Binding ShowInjectionFields}" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Behavior" Foreground="#9FB0D8" Width="100" VerticalAlignment="Center" />
                                    <ComboBox Width="280"
                                              ItemsSource="{Binding InjectionBehaviors}"
                                              SelectedItem="{Binding InjectionBehavior}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Payload" Foreground="#9FB0D8" Width="100" VerticalAlignment="Center" />
                                    <ComboBox Width="280"
                                              ItemsSource="{Binding Payloads}"
                                              SelectedItem="{Binding InjectionPayloadName}" />
                                </StackPanel>
                                <StackPanel IsVisible="{Binding ShowInjectionPidField}" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Target PID" Foreground="#9FB0D8" Width="100" VerticalAlignment="Center" />
                                    <TextBox Width="280" Text="{Binding InjectionTargetPid}" Watermark="Process ID" />
                                </StackPanel>
                                <StackPanel IsVisible="{Binding ShowInjectionProgramField}" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Program" Foreground="#9FB0D8" Width="100" VerticalAlignment="Center" />
                                    <TextBox Width="280" Text="{Binding InjectionProgramName}" Watermark="Program name" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Classes="Primary"
                    Content="Run Chain"
                    HorizontalAlignment="Right"
                    Command="{Binding RunChainCommand}" />
        </Grid>
    </Border>

</UserControl>
