<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="using:Mabean.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             x:Class="Mabean.Views.BehaviorSimulationView"
             xmlns:vm="using:Mabean.ViewModels"
             x:DataType="vm:BehaviorSimulationViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="#070C14"/>
            <Setter Property="BorderBrush" Value="#2A2E39"/>
            <Setter Property="Foreground" Value="#D1D4DC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="MinHeight" Value="0"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="#070C14"/>
            <Setter Property="BorderBrush" Value="#2A2E39"/>
            <Setter Property="Foreground" Value="#D1D4DC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>
        <Style Selector="Button.execBtn">
            <Setter Property="Background" Value="#C6F36E"/>
            <Setter Property="Foreground" Value="#070C14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.execBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D4F87A"/>
        </Style>
        <Style Selector="Button.browseBtn">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="BorderBrush" Value="#2A2E39"/>
            <Setter Property="BorderThickness" Value="0,1,1,1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.browseBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#161D2C"/>
            <Setter Property="TextElement.Foreground" Value="#C6F36E"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#070C14" RowDefinitions="*">

        <!-- Configuration panel -->
        <Border>
        <Grid RowDefinitions="*,Auto">

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Section header -->
                    <Border Background="#090E18" BorderBrush="#2A2E39" BorderThickness="0,0,0,1" Padding="14,9">
                        <TextBlock Text="CONFIGURATION" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280"/>
                    </Border>

                    <!-- Fields -->
                    <Border Padding="14,12,14,12">
                    <StackPanel Spacing="10">

                        <Grid ColumnDefinitions="110,*">
                            <TextBlock Text="BEHAVIOR TYPE" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Behaviors}"
                                      SelectedItem="{Binding SelectedBehavior}"
                                      HorizontalAlignment="Stretch"/>
                        </Grid>

                        <Border Height="1" Background="#1E2639"/>

                        <Grid ColumnDefinitions="110,*" IsVisible="{Binding ShowPayloadField}">
                            <TextBlock Text="PAYLOAD" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Payloads}"
                                      SelectedItem="{Binding SelectedPayload}"
                                      HorizontalAlignment="Stretch"/>
                        </Grid>

                        <Grid ColumnDefinitions="110,*,28" IsVisible="{Binding ShowPuidField}">
                            <TextBlock Text="TARGET PUID" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding Puid}" Watermark="Process ID"/>
                            <Button Grid.Column="2" Classes="browseBtn"
                                    Content="⊕"
                                    ToolTip.Tip="Browse processes"
                                    Command="{Binding BrowseProcessesCommand}"/>
                        </Grid>

                        <Grid ColumnDefinitions="110,*,28" IsVisible="{Binding ShowProgramNameField}">
                            <TextBlock Text="PROGRAM NAME" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding ProgramName}" Watermark="Program name"/>
                            <Button Grid.Column="2" Classes="browseBtn"
                                    Content="⊕"
                                    ToolTip.Tip="Browse programs"
                                    Command="{Binding BrowseProgramsCommand}"/>
                        </Grid>

                    </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Execute bar -->
            <Border Grid.Row="1"
                    Background="#090E18"
                    BorderBrush="#2A2E39"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                <Button Classes="execBtn"
                        Content="EXECUTE"
                        HorizontalAlignment="Right"
                        Command="{Binding ExecuteBehaviorCommand}"/>
            </Border>

        </Grid>
        </Border>


    </Grid>

</UserControl>
