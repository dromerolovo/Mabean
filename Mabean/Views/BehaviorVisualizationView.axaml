<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Mabean.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="Mabean.Views.BehaviorVisualizationView"
             x:DataType="vm:BehaviorVisualizationViewModel"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

   <Border Padding="20">
     <Grid RowDefinitions="Auto,*" RowSpacing="16">
       <StackPanel Grid.Row="0" HorizontalAlignment="Left">
         <TextBlock Classes="h4" Text="Behavior Analyzer" />
         <Border Height="8" />
           <Border Height="12"/>
         <ComboBox Width="255"
                   ItemsSource="{Binding Behaviors}"
                   SelectedItem="{Binding SelectedBehavior}" />
           <Border Height="12"/>
       </StackPanel>

       <Border Grid.Row="1">
         <Border.Background>
           <DrawingBrush TileMode="Tile"
                         DestinationRect="0,0,80,46"
                         Stretch="None">
             <DrawingBrush.Drawing>
               <DrawingGroup>
                 <GeometryDrawing>
                   <GeometryDrawing.Pen>
                     <Pen Brush="#2B364A" Thickness="1" />
                   </GeometryDrawing.Pen>
                   <GeometryDrawing.Geometry>
                     <GeometryGroup>
                       <LineGeometry StartPoint="40,0" EndPoint="80,23" />
                       <LineGeometry StartPoint="0,23" EndPoint="40,0" />
                       <LineGeometry StartPoint="0,23" EndPoint="40,46" />
                       <LineGeometry StartPoint="40,46" EndPoint="80,23" />
                     </GeometryGroup>
                   </GeometryDrawing.Geometry>
                 </GeometryDrawing>
               </DrawingGroup>
             </DrawingBrush.Drawing>
           </DrawingBrush>
         </Border.Background>

         <ScrollViewer HorizontalScrollBarVisibility="Auto"
                       VerticalScrollBarVisibility="Auto">
           <Grid Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">

             <!-- Connector lines (behind nodes) -->
             <ItemsControl ItemsSource="{Binding Connectors}">
               <ItemsControl.ItemsPanel>
                 <ItemsPanelTemplate>
                   <Canvas />
                 </ItemsPanelTemplate>
               </ItemsControl.ItemsPanel>
               <ItemsControl.ItemTemplate>
                 <DataTemplate x:DataType="vm:ConnectorDisplay">
                   <Line StartPoint="{Binding StartPoint}"
                         EndPoint="{Binding EndPoint}"
                         Stroke="#C6F36E" StrokeThickness="2" />
                 </DataTemplate>
               </ItemsControl.ItemTemplate>
             </ItemsControl>

             <!-- Nodes (in front) -->
             <ItemsControl ItemsSource="{Binding Nodes}">
               <ItemsControl.ItemsPanel>
                 <ItemsPanelTemplate>
                   <Canvas />
                 </ItemsPanelTemplate>
               </ItemsControl.ItemsPanel>
               <ItemsControl.ItemContainerTheme>
                 <ControlTheme TargetType="ContentPresenter" x:DataType="vm:VisualizationNodeDisplay">
                   <Setter Property="Canvas.Left" Value="{Binding X}" />
                   <Setter Property="Canvas.Top" Value="{Binding Y}" />
                   <Setter Property="ZIndex"      Value="{Binding ZIndex}" />
                 </ControlTheme>
               </ItemsControl.ItemContainerTheme>
               <ItemsControl.ItemTemplate>
                 <DataTemplate x:DataType="vm:VisualizationNodeDisplay">
                   <Border Background="#1F2636" CornerRadius="8" Padding="12" Width="260">
                     <StackPanel Spacing="6">
                       <TextBlock Text="{Binding Name}" Foreground="#C6F36E" FontWeight="Bold" />
                       <TextBlock Text="{Binding FunctionName}" Foreground="#9FB0D8" />
                       <TextBlock Text="{Binding Description}" Foreground="#9FB0D8" TextWrapping="Wrap" />
                       <Expander Header="Parameters" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                         <ItemsControl ItemsSource="{Binding Parameters}">
                           <ItemsControl.ItemTemplate>
                             <DataTemplate x:DataType="vm:VisualizationNodeParameterDisplay">
                               <StackPanel Spacing="2" Margin="0,6,0,0">
                                 <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                 <TextBlock Text="{Binding Value}" Foreground="#C6F36E" />
                                 <TextBlock Text="{Binding Description}" Foreground="#9FB0D8" TextWrapping="Wrap" />
                               </StackPanel>
                             </DataTemplate>
                           </ItemsControl.ItemTemplate>
                         </ItemsControl>
                       </Expander>
                     </StackPanel>
                   </Border>
                 </DataTemplate>
               </ItemsControl.ItemTemplate>
             </ItemsControl>

           </Grid>
         </ScrollViewer>
       </Border>
     </Grid>
   </Border>

</UserControl>
