<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:vm="clr-namespace:Mabean.ViewModels"
             xmlns:models="clr-namespace:Mabean.Models"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="Mabean.Views.EventsView"
             x:DataType="vm:EventsViewModel"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Styles>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="#070C14"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#9FB0D8"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E2639"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="RowHeight" Value="36"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#090E18"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#2A2E39"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="DataGridRow:selected">
            <Setter Property="Background" Value="#111D30"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#070C14" RowDefinitions="*,Auto">

        <!-- Events table fills available space -->
        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding SecurityEvents}"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">

            <DataGrid.Columns>

                <DataGridTextColumn Width="90"
                                    Binding="{Binding RecordId}"
                                    Header="RECORD ID"/>

                <DataGridTemplateColumn Width="160"
                                        Header="TIMESTAMP"
                                        SortMemberPath="TimeCreated">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="models:SecurityEvent">
                            <TextBlock Margin="12,0"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="#9FB0D8"
                                       Text="{Binding TimeCreated, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Width="70"
                                    Binding="{Binding EventId}"
                                    Header="EVENT ID"/>

                <DataGridTextColumn Width="190"
                                    Binding="{Binding Source}"
                                    Header="SOURCE"/>

                <DataGridTextColumn Width="140"
                                    Binding="{Binding TaskCategory}"
                                    Header="CATEGORY"/>

                <DataGridTemplateColumn Width="*"
                                        CanUserSort="False"
                                        Header="MESSAGE">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="models:SecurityEvent">
                            <TextBlock Margin="12,0"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="#9FB0D8"
                                       Text="{Binding Message}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding Message}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="44"
                                        CanUserResize="False"
                                        CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="models:SecurityEvent">
                            <CheckBox HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsChecked="{ReflectionBinding IsSelected}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Analysis panel -->
        <Border Grid.Row="1"
                Background="#090E18"
                BorderBrush="#2A2E39"
                BorderThickness="0,1,0,0"
                MaxHeight="160">
            <Grid RowDefinitions="Auto,*">

                <!-- Analysis header -->
                <Border Grid.Row="0" BorderBrush="#2A2E39" BorderThickness="0,0,0,1" Padding="14,8">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="ANALYSIS" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                            <Border Background="#161D2C" BorderBrush="#2A2E39" BorderThickness="1"
                                    Padding="7,2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding SecurityEvents.Count}"
                                               FontSize="10" Foreground="#9FB0D8"/>
                                    <TextBlock Text="EVENTS" FontSize="10" Foreground="#6B7280"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Analysis content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Border Padding="14,10">
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Text="SUSPICIOUSNESS" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Suspiciousness}"
                                           FontSize="11" Foreground="#C6F36E"/>
                            </Grid>
                            <TextBlock Text="EXPLANATION" FontSize="10" FontWeight="SemiBold" Foreground="#6B7280" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding Explanation}"
                                       FontSize="11" Foreground="#9FB0D8"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

            </Grid>
        </Border>

    </Grid>

</UserControl>
