<shadui:Window
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:vm="using:Mabean.ViewModels"
xmlns:views="using:Mabean.Views"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
mc:Ignorable="d"
d:DesignWidth="1440"
d:DesignHeight="860"
x:Class="Mabean.Views.MainWindow"
x:DataType="vm:MainWindowViewModel"
x:Name="Window"
Title="Mabean"
Width="1440"
Height="860"
MinWidth="1100"
WindowStartupLocation="CenterScreen"
SaveWindowState="True"
TitleFontWeight="SemiBold">

	<shadui:Window.LogoContent>
		<PathIcon Data="{x:Static shadui:Icons.Logo}" Height="14" Width="14" Margin="8,8,0,8" />
	</shadui:Window.LogoContent>

	<shadui:Window.RightWindowTitleBarContent>
		<Button Background="{DynamicResource SidebarBackgroundColor}"
		        CornerRadius="{DynamicResource MdCornerRadius}"
		        Height="30" Width="30" ToolTip.Tip="Settings">
			<PathIcon Data="{x:Static shadui:Icons.Settings}" Width="16" Height="16" />
		</Button>
	</shadui:Window.RightWindowTitleBarContent>

	<shadui:Window.Styles>

		<!-- Tab button: inactive -->
		<Style Selector="Button.tabBtn">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="0"/>
			<Setter Property="Padding" Value="16,0"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="Foreground" Value="#6B7280"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Template">
				<ControlTemplate>
					<Panel>
						<Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
							<ContentPresenter Content="{TemplateBinding Content}"
							                  VerticalAlignment="Center"
							                  HorizontalAlignment="Center"
							                  TextElement.Foreground="{TemplateBinding Foreground}"
							                  TextElement.FontSize="{TemplateBinding FontSize}"
							                  TextElement.FontWeight="{TemplateBinding FontWeight}" />
						</Border>
						<Border x:Name="Indicator" Height="2" VerticalAlignment="Bottom" Background="Transparent" />
					</Panel>
				</ControlTemplate>
			</Setter>
		</Style>

		<!-- Tab button: active state -->
		<Style Selector="Button.tabBtn.active">
			<Setter Property="Foreground" Value="#C6F36E"/>
		</Style>
		<Style Selector="Button.tabBtn.active /template/ Border#Indicator">
			<Setter Property="Background" Value="#C6F36E"/>
		</Style>

		<!-- Tab button: hover -->
		<Style Selector="Button.tabBtn:pointerover">
			<Setter Property="Foreground" Value="#D1D4DC"/>
		</Style>

		<!-- Pane action button -->
		<Style Selector="Button.paneBtn">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="#2A2E39"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="Padding" Value="10,4"/>
			<Setter Property="Height" Value="26"/>
			<Setter Property="Foreground" Value="#6B7280"/>
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
		<Style Selector="Button.paneBtn:pointerover">
			<Setter Property="Foreground" Value="#D1D4DC"/>
			<Setter Property="BorderBrush" Value="#3D4455"/>
		</Style>

	</shadui:Window.Styles>

	<Grid ColumnDefinitions="420,*,380">

		<!-- ══════════════════════════════════
		         LEFT PANE — Attack Builder
		     ══════════════════════════════════ -->
		<Grid Grid.Column="0" RowDefinitions="40,*">

			<Border Grid.Row="0"
			        Background="#0D1117"
			        BorderBrush="#2A2E39"
			        BorderThickness="0,0,1,1">
				<Grid ColumnDefinitions="*,Auto" Margin="0,0,8,0">
					<StackPanel Grid.Column="0" Orientation="Horizontal">
						<Button Classes="tabBtn"
						        Classes.active="{Binding ShowChain}"
						        Command="{Binding SelectChainCommand}"
						        Content="CHAIN" />
						<Button Classes="tabBtn"
						        Classes.active="{Binding ShowSimulate}"
						        Command="{Binding SelectSimulateCommand}"
						        Content="SIMULATE" />
						<Button Classes="tabBtn"
						        Classes.active="{Binding ShowPayloads}"
						        Command="{Binding SelectPayloadsCommand}"
						        Content="PAYLOADS" />
					</StackPanel>
				</Grid>
			</Border>

			<Border Grid.Row="1" BorderBrush="#2A2E39" BorderThickness="0,0,1,0">
				<Grid>
					<Border IsVisible="{Binding ShowChain}">
						<views:BehaviorChainView DataContext="{Binding BehaviorChainViewModel}" />
					</Border>
					<Border IsVisible="{Binding ShowSimulate}">
						<views:BehaviorSimulationView DataContext="{Binding BehaviorSimulationViewModel}" />
					</Border>
					<Border IsVisible="{Binding ShowPayloads}">
						<views:PayloadManagerView DataContext="{Binding PayloadManagerViewModel}" />
					</Border>
				</Grid>
			</Border>

		</Grid>

		<!-- ══════════════════════════════════
		         MIDDLE PANE — Events / Processes
		     ══════════════════════════════════ -->
		<Grid Grid.Column="1" RowDefinitions="40,*">

			<Border Grid.Row="0"
			        Background="#0D1117"
			        BorderBrush="#2A2E39"
			        BorderThickness="0,0,1,1">
				<Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,0,8,0">
					<StackPanel Grid.Column="0" Orientation="Horizontal">
						<Button Classes="tabBtn"
						        Classes.active="{Binding ShowEvents}"
						        Command="{Binding SelectEventsCommand}"
						        Content="EVENTS" />
						<Button Classes="tabBtn"
						        Classes.active="{Binding ShowProcesses}"
						        Command="{Binding SelectProcessesCommand}"
						        Content="PROCESSES" />
					</StackPanel>
					<Border Grid.Column="1"
					        Background="#161D2C"
					        BorderBrush="#2A2E39"
					        BorderThickness="1"
					        CornerRadius="10"
					        Padding="7,2" Margin="4,0,0,0"
					        VerticalAlignment="Center"
					        IsVisible="{Binding ShowEvents}">
						<TextBlock Text="{Binding EventsViewModel.SecurityEvents.Count}"
						           FontSize="10" Foreground="#9FB0D8" />
					</Border>
					<StackPanel Grid.Column="3"
					            Orientation="Horizontal"
					            Spacing="6" VerticalAlignment="Center"
					            IsVisible="{Binding ShowEvents}">
						<Button Classes="paneBtn"
						        Command="{Binding EventsViewModel.AnalyzeSelectedCommand}"
						        Content="ANALYZE" />
						<Button Classes="paneBtn"
						        Command="{Binding EventsViewModel.ClearEventsCommand}"
						        Content="CLEAR" />
					</StackPanel>
					<StackPanel Grid.Column="3"
					            Orientation="Horizontal"
					            Spacing="6" VerticalAlignment="Center"
					            IsVisible="{Binding ShowProcesses}">
						<Button Classes="paneBtn"
						        Command="{Binding ProcessFinderViewModel.LoadProcessesCommand}"
						        Content="REFRESH" />
					</StackPanel>
				</Grid>
			</Border>

			<Grid Grid.Row="1">
				<Border IsVisible="{Binding ShowEvents}">
					<views:EventsView DataContext="{Binding EventsViewModel}" />
				</Border>
				<Border IsVisible="{Binding ShowProcesses}">
					<views:ProcessFinderView DataContext="{Binding ProcessFinderViewModel}" />
				</Border>
			</Grid>

		</Grid>

		<!-- ══════════════════════════════════
		         RIGHT PANE — Call Graph
		     ══════════════════════════════════ -->
		<Border Grid.Column="2" BorderBrush="#2A2E39" BorderThickness="1,0,0,0">
		<Grid RowDefinitions="40,*">

			<Border Grid.Row="0"
			        Background="#0D1117"
			        BorderBrush="#2A2E39"
			        BorderThickness="0,0,0,1">
				<TextBlock Text="CALL GRAPH"
				           FontSize="11" FontWeight="SemiBold"
				           Foreground="#6B7280"
				           Margin="14,0"
				           VerticalAlignment="Center" />
			</Border>

			<views:BehaviorVisualizationView Grid.Row="1"
			                                 DataContext="{Binding BehaviorVisualizationViewModel}" />

		</Grid>
		</Border>

	</Grid>
</shadui:Window>
